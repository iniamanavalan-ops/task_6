class Student {


    int studentId;
    String studentName;
    double studentMarks;
    

    Student() {
        studentId = 0;
        studentName = "Unknown";
        studentMarks = 0.0;
        System.out.println("\n[Default Constructor]");
        displayDetails();
    }
    
    
    Student(int id, String name) {

        studentId = id;
        studentName = name;
        studentMarks = 0.0;
        System.out.println("\n[Parameterized Constructor - 2 params]");
        displayDetails();
    }
    

    Student(int id, String name, double marks) {

        studentId = id;
        studentName = name;
        studentMarks = marks;
        System.out.println("\n[Parameterized Constructor - 3 params]");
        displayDetails();
    }
    

    void displayDetails() {

        System.out.println("Student ID: " + studentId);
        System.out.println("Student Name: " + studentName);
        System.out.println("Student Marks: " + studentMarks);
        System.out.println("------------------------");
    }
    

    public static void main(String[] args) {


        System.out.println("=== Constructor Implementation Demo ===");

        
        Student s1 = new Student();                   
        Student s2 = new Student(101, "Alice");        
        Student s3 = new Student(102, "Bob", 85.5);   
        Student s4 = new Student(103, "Charlie", 92.0); 
        Student s5 = new Student(104, "Diana");        
    }
}



